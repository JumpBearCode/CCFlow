TELEGRAM_BOT_TOKEN="your-bot-token-from-botfather"
TELEGRAM_ALLOWED_USERS="123456789,987654321"
CLAUDE_SUBPROCESS_TIMEOUT="600"
OUTPUT_FORMAT="streaming"

# Table image: render markdown tables as PNG via Playwright (requires: playwright install chromium)
ENABLE_TABLE_IMAGE="false"

# Sandbox: restrict claude subprocess to this directory
# CCFLOW_CWD="/path/to/project"
# CCFLOW_SANDBOX="true"
